#!/usr/bin/env bash
# git-land: Cherry-pick the current branch's commits onto main, then rebase.
#
# Usage: git land [--all | -n <count>]
#
# From a feature branch, this:
#   1. Stashes uncommitted changes (if any)
#   2. Cherry-picks the last commit (or --all commits since divergence) onto main
#   3. Rebases the current branch on main (dropping the duplicates)
#   4. Pops the stash (if one was created)
#
# This is useful in a worktree setup where you want commits to land on main
# without merging or PRs, and keep your feature branch rebased.

set -euo pipefail

# Parse args
COUNT=1
while [[ $# -gt 0 ]]; do
  case "$1" in
    --all|-a)
      COUNT="all"
      shift
      ;;
    -n)
      COUNT="$2"
      shift 2
      ;;
    --help|-h)
      echo "Usage: git land [--all | -n <count>]"
      echo ""
      echo "Cherry-pick commits from the current branch onto main, then rebase."
      echo ""
      echo "Options:"
      echo "  (default)   Land the last commit only"
      echo "  --all, -a   Land all commits since divergence from main"
      echo "  -n <count>  Land the last <count> commits"
      echo "  --help, -h  Show this help"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Run 'git land --help' for usage."
      exit 1
      ;;
  esac
done

BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [ "$BRANCH" = "main" ]; then
  echo "Already on main. Nothing to land."
  exit 0
fi

# Check for uncommitted changes
STASHED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Stashing uncommitted changes..."
  git stash --include-untracked
  STASHED=true
fi

# Determine which commits to cherry-pick
if [ "$COUNT" = "all" ]; then
  MERGE_BASE="$(git merge-base HEAD main)"
  COMMITS="$(git rev-list --reverse "$MERGE_BASE"..HEAD)"
  COMMIT_COUNT="$(echo "$COMMITS" | wc -l | tr -d ' ')"
  echo "Landing $COMMIT_COUNT commit(s) onto main..."
else
  COMMITS="$(git rev-list --reverse -"$COUNT" HEAD)"
  COMMIT_COUNT="$COUNT"
  echo "Landing $COMMIT_COUNT commit(s) onto main..."
fi

if [ -z "$COMMITS" ]; then
  echo "No commits to land."
  if [ "$STASHED" = true ]; then
    git stash pop
  fi
  exit 0
fi

# Cherry-pick onto main
git checkout main --quiet
for COMMIT in $COMMITS; do
  SHORT="$(git rev-parse --short "$COMMIT")"
  SUBJECT="$(git log --format='%s' -1 "$COMMIT")"
  echo "  cherry-pick $SHORT $SUBJECT"
  git cherry-pick "$COMMIT" --quiet
done

# Back to feature branch and rebase
git checkout "$BRANCH" --quiet
echo "Rebasing $BRANCH on main..."
git rebase main --quiet

echo ""
echo "Done. $COMMIT_COUNT commit(s) landed on main, $BRANCH rebased."

if [ "$STASHED" = true ]; then
  echo "Restoring stashed changes..."
  git stash pop
fi
