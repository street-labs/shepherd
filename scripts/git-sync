#!/usr/bin/env bash
# git-sync: Rebase the current branch on main.
#
# Usage: git sync
#
# This is the counterpart to `git land`. After someone lands commits on main
# (from any worktree), other worktrees run `git sync` to pick up those changes.
#
# This:
#   1. Stashes uncommitted changes (if any)
#   2. Rebases the current branch on main
#   3. Pops the stash (if one was created)

set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo "Usage: git sync"
  echo ""
  echo "Rebase the current branch on main."
  echo "Stashes and restores uncommitted changes automatically."
  exit 0
fi

BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [ "$BRANCH" = "main" ]; then
  echo "Already on main. Nothing to sync."
  exit 0
fi

# Check for uncommitted changes
STASHED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Stashing uncommitted changes..."
  git stash --include-untracked
  STASHED=true
fi

echo "Rebasing $BRANCH on main..."
git rebase main --quiet

AHEAD="$(git rev-list main..HEAD --count)"
echo "Done. $BRANCH is up to date with main ($AHEAD commit(s) ahead)."

if [ "$STASHED" = true ]; then
  echo "Restoring stashed changes..."
  git stash pop
fi
